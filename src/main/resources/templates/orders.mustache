<!DOCTYPE html>
<html lang = "en">
<head>
    <title>Orders</title>
</head>
<body>

<h1>Orders</h1>

{{#hasOrders}}

    <h2>Active Orders</h2>

    {{#activeOrders}}
        <p>
            Order ID: {{orderId}} <br>
            Order Status: {{status}} <br>

        </p>
        <hr>
    {{/activeOrders}}

    <h2>Completed Orders</h2>
    {{#completedOrders}}
        <p>
            Order ID: {{orderId}} <br>
            Order Status: {{status}}
        </p>
        <hr>
    {{/completedOrders}}

{{/hasOrders}}

<form action="/saveorder" method="post">

    <label>Items</label>
    <input type="text" name="items">

    <label>Total Price</label>
    <input type="number" name="totalPrice" step="0.01" required>
    <label>Message</label>
    <input type="text" name="orderMessage">

    <button type="submit">Create Order</button>

</form>

</body>
</html>