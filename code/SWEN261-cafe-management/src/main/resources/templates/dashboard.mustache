<!DOCTYPE html>
<html lang="en">
<head>
    <title>Admin Dashboard — Cafe Management</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --cream: #faf6f1;
            --espresso: #2c1a0e;
            --coffee: #6b3f1f;
            --latte: #c9a882;
            --foam: #f0e6d8;
            --steam: #e8ddd0;
            --red: #c0392b;
            --green: #2d6a4f;
            --gold: #b8860b;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background: var(--cream);
            font-family: 'DM Sans', sans-serif;
            color: var(--espresso);
            min-height: 100vh;
        }

        header {
            background: var(--espresso);
            padding: 18px 40px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        header h1 {
            font-family: 'Playfair Display', serif;
            color: var(--latte);
            font-size: 1.6rem;
            letter-spacing: 0.04em;
        }
        header span {
            color: var(--steam);
            font-size: 0.85rem;
            opacity: 0.7;
        }

        .page {
            max-width: 960px;
            margin: 0 auto;
            padding: 50px 24px 80px;
        }

        .welcome {
            font-family: 'Playfair Display', serif;
            font-size: 1.5rem;
            color: var(--coffee);
            margin-bottom: 8px;
        }
        .welcome-sub {
            font-size: 0.9rem;
            color: var(--latte);
            margin-bottom: 40px;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            margin-bottom: 50px;
        }

        .card {
            background: white;
            border: 1.5px solid var(--steam);
            border-radius: 12px;
            padding: 32px 24px;
            text-align: center;
            box-shadow: 0 2px 12px rgba(44,26,14,0.06);
            transition: box-shadow 0.2s, transform 0.2s;
            text-decoration: none;
            display: block;
            color: var(--espresso);
        }
        .card:hover {
            box-shadow: 0 6px 20px rgba(44,26,14,0.12);
            transform: translateY(-2px);
        }
        .card .card-icon {
            font-size: 2rem;
            margin-bottom: 14px;
        }
        .card .card-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--espresso);
            margin-bottom: 6px;
        }
        .card .card-desc {
            font-size: 0.82rem;
            color: var(--latte);
        }

        .logout-section {
            text-align: center;
            padding-top: 10px;
        }
        .logout-section a {
            color: var(--red);
            text-decoration: none;
            font-weight: 500;
            font-size: 0.9rem;
            border: 1.5px solid #fdecea;
            padding: 10px 24px;
            border-radius: 8px;
            display: inline-block;
            transition: background 0.2s;
        }
        .logout-section a:hover {
            background: #fdecea;
        }
    </style>
</head>
<body>

<header>
    <h1>☕ Cafe Management</h1>
    <span>Admin Dashboard</span>
</header>

<div class="page">

    <p class="welcome">Welcome back 👋</p>
    <p class="welcome-sub">What would you like to manage today?</p>

    {{#errorMsg}}
    <div style="
        background-color: #fdf0ec;
        border-left: 4px solid #e74c3c;
        padding: 12px;
        margin-bottom: 20px;
        color: #c0392b;
        border-radius: 6px;
    ">
        ⚠ {{errorMsg}}
    </div>
    {{/errorMsg}}

    <div class="grid">

        <a href="/orders" class="card">
            <div class="card-icon">📋</div>
            <div class="card-title">Manage Orders</div>
            <div class="card-desc">View, create, and track orders</div>
        </a>

        <a href="/items" class="card">
            <div class="card-icon">📦</div>
            <div class="card-title">Manage Items</div>
            <div class="card-desc">View, add, and remove items</div>
        </a>

        <a href="/pricing" class="card">
            <div class="card-icon">💰</div>
            <div class="card-title">Pricing Plans</div>
            <div class="card-desc">View and update available pricing packages</div>
        </a>

        <a href="/users/staff" class="card">
            <div class="card-icon">👥</div>
            <div class="card-title">Staff Accounts</div>
            <div class="card-desc">Create staff accounts and assign roles</div>
        </a>


    </div>

    <div class="logout-section">
        <a href="/logout">Disconnect</a>
    </div>

</div>

</body>
</html>
