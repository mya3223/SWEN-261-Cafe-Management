<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Admin Dashboard</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            background-color: #f5f5f5;
        }

        header {
            background-color: #333;
            color: white;
            padding: 15px;
            text-align: center;
        }

        .container {
            padding: 20px;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
        }

        .card {
            background: white;
            padding: 20px;
            border-radius: 10px;
            text-align: center;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .card a {
            text-decoration: none;
            color: #333;
            font-weight: bold;
        }

        .card:hover {
            background-color: #eaeaea;
        }

        .logout {
            margin-top: 30px;
            text-align: center;
        }

        .logout a {
            color: red;
            text-decoration: none;
            font-weight: bold;
        }
    </style>
</head>

<body>

<header>
    <h1>Admin Dashboard</h1>
</header>

<div class="container">

    <div class="grid">

        <div class="card">
            <a href="/orders"> Manage Orders</a>
        </div>

        <div class="card">
            <a href="/pricing">See Pricing Plans</a>
        </div>

    </div>

    <div class="logout">
        <a href="/logout">Disconnect</a>
    </div>

</div>

</body>
</html>