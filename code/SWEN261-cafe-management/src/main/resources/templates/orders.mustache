<!DOCTYPE html>

<html lang="en">

<head>

<title>Orders</title>

</head>

<body>

<h1>Orders</h1>
{{#errorMsg}}
<p style="color:red;">{{errorMsg}}</p>
{{/errorMsg}}

<form action="/orders" method="get">

<input type="text" name="search" placeholder="Search by Order ID">

<select name="status">
<option value=""> Filtering Type </option>
<option value="pending">Pending</option>
<option value="delivered">Delivered</option>
</select>

<label>From:</label>
<input type="Date" name="From">

<label>To:</label>
<input type="Date" name="To">

<button type="submit">Search</button>
<a href="/orders">Clear</a>

</form>

<p>Showing {{resultCount}} orders</p>

{{#hasOrders}}

<h2>Active Orders</h2>
{{#activeOrders}}


<p>
Order ID: {{orderId}} <br>
Order Status: {{status}} <br>
</p>


<hr>
{{/activeOrders}}

<h2>Completed Orders</h2>
{{#completedOrders}}
<p>
<strong>Order completed successfully</strong><br>

Order ID: {{orderId}} <br>
Order Status: {{status}}

</p>

<hr>
{{/completedOrders}}

{{/hasOrders}}

{{#noOrders}}

<p>

No orders found matching your search.

</p>

{{/noOrders}}


<form action="/saveorder" method="post">

<label>Items</label>
<input type="text" name="items">

<label>Total Price</label>
    <input type="number" name="totalPrice" step="0.01" required>
    <label>Message</label>
    <input type="text" name="orderMessage">

<button type="submit">Create Order</button>

</form>

</body>
</html>
