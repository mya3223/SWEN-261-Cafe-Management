<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Staff Accounts — Cafe Management</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            min-height: 100vh;
            display: flex;
            font-family: 'DM Sans', sans-serif;
            background-color: #f5f0eb;
        }

        .side-panel {
            width: 35%;
            background-color: #3b2314;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 60px;
            position: relative;
            overflow: hidden;
        }

        .side-panel::before {
            content: '';
            position: absolute;
            width: 320px;
            height: 320px;
            border-radius: 50%;
            background: rgba(230, 126, 34, 0.15);
            top: -80px;
            left: -80px;
        }

        .side-panel::after {
            content: '';
            position: absolute;
            width: 220px;
            height: 220px;
            border-radius: 50%;
            background: rgba(230, 126, 34, 0.1);
            bottom: -60px;
            right: -40px;
        }

        .side-panel .logo-icon {
            font-size: 56px;
            margin-bottom: 24px;
            position: relative;
            z-index: 1;
        }

        .side-panel h1 {
            font-family: 'Playfair Display', serif;
            color: #fff;
            font-size: 32px;
            text-align: center;
            line-height: 1.3;
            position: relative;
            z-index: 1;
        }

        .side-panel p {
            color: rgba(255,255,255,0.55);
            margin-top: 14px;
            font-size: 14px;
            text-align: center;
            position: relative;
            z-index: 1;
        }

        .divider-line {
            width: 40px;
            height: 2px;
            background-color: #e67e22;
            margin: 20px auto;
            position: relative;
            z-index: 1;
        }

        .main-panel {
            flex: 1;
            padding: 50px;
            display: flex;
            justify-content: center;
            align-items: flex-start;
        }

        .staff-box {
            width: 100%;
            max-width: 750px;
        }

        .staff-box h2 {
            font-family: 'Playfair Display', serif;
            font-size: 28px;
            color: #3b2314;
            margin-bottom: 6px;
        }

        .subtitle {
            color: #9e8070;
            font-size: 14px;
            margin-bottom: 30px;
        }

        .form-card, .users-card {
            background-color: white;
            border-radius: 12px;
            padding: 28px;
            margin-bottom: 28px;
            box-shadow: 0 8px 24px rgba(59, 35, 20, 0.08);
        }

        .field {
            margin-bottom: 20px;
        }

        .field label {
            display: block;
            font-size: 13px;
            font-weight: 500;
            color: #5c3d2e;
            margin-bottom: 7px;
            letter-spacing: 0.04em;
            text-transform: uppercase;
        }

        .field input, .field select {
            width: 100%;
            padding: 13px 16px;
            border: 2px solid #ddd0c8;
            border-radius: 8px;
            font-size: 15px;
            font-family: 'DM Sans', sans-serif;
            background-color: #fff;
            color: #3b2314;
            outline: none;
        }

        .field input:focus, .field select:focus {
            border-color: #e67e22;
        }

        .error-box {
            background-color: #fdf0ec;
            border: 1px solid #f0c4b4;
            border-left: 4px solid #e74c3c;
            border-radius: 8px;
            padding: 12px 16px;
            margin-bottom: 20px;
            color: #c0392b;
            font-size: 14px;
        }

        .submit-btn {
            width: 100%;
            padding: 14px;
            background-color: #3b2314;
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-family: 'DM Sans', sans-serif;
            font-weight: 500;
            cursor: pointer;
        }

        .submit-btn:hover {
            background-color: #e67e22;
        }

        .users-card h3 {
            color: #3b2314;
            margin-bottom: 16px;
        }

        .user-row {
            padding: 12px 0;
            border-bottom: 1px solid #eee2da;
            color: #5c3d2e;
            font-size: 15px;
        }

        .user-row:last-child {
            border-bottom: none;
        }

        .back-link {
            display: inline-block;
            margin-top: 10px;
            color: #e67e22;
            text-decoration: none;
            font-weight: 500;
        }

        .back-link:hover {
            text-decoration: underline;
        }

        @media (max-width: 700px) {
            .side-panel {
                display: none;
            }

            .main-panel {
                padding: 30px 20px;
            }
        }
    </style>
</head>
<body>

<div class="side-panel">
    <div class="logo-icon">👥</div>
    <h1>Staff Account Creation</h1>
    <div class="divider-line"></div>
    <p>Create staff accounts and assign roles for your cafe team.</p>
</div>

<div class="main-panel">
    <div class="staff-box">

        <h2>Create Staff Account</h2>
        <p class="subtitle">Only the owner can create staff accounts</p>

        {{#errorMsg}}
            <div class="error-box">
                ⚠ {{errorMsg}}
            </div>
        {{/errorMsg}}

        <div class="form-card">
            <form action="/users/staff" method="post">
                <div class="field">
                    <label for="name">Name</label>
                    <input type="text" id="name" name="name" placeholder="Staff name" required>
                </div>

                <div class="field">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" placeholder="staff@example.com" required>
                </div>

                <div class="field">
                    <label for="password">Password</label>
                    <input type="password" id="password" name="password" placeholder="••••••••" required>
                </div>

                <div class="field">
                    <label for="role">Role</label>
                    <select id="role" name="role">
                        <option value="STAFF">STAFF</option>
                        <option value="MANAGER">MANAGER</option>
                    </select>
                </div>

                <button class="submit-btn" type="submit">Create Staff</button>
            </form>
        </div>

        <div class="users-card">
            <h3>All Users</h3>

            {{#users}}
                <div class="user-row">
                    {{name}} - {{email}} - {{role}}
                </div>
            {{/users}}
        </div>

        <a class="back-link" href="/dashboard">← Back to Dashboard</a>

    </div>
</div>

</body>
</html>
